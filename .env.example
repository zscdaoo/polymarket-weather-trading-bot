# ─── Polymarket / wallet ──────────────────────────────────────────────────────
# Private key of the wallet that holds your USDC and signs orders (0x-prefixed).
# NEVER commit the real .env. Use a dedicated trading wallet, not your main one.
PRIVATE_KEY=0xyour_private_key_here

# Your Polymarket "funder" / proxy address (the address shown on your profile that
# holds the USDC used for trading). For an EOA browser wallet this equals your
# wallet address; for Magic/email logins it is the proxy address.
FUNDER_ADDRESS=0xyour_polymarket_address_here

# Signature type: 0 = EOA/browser wallet, 1 = Magic/email (proxy), 2 = Gnosis safe.
SIGNATURE_TYPE=0

# API host endpoints (defaults are correct for production Polygon).
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
CHAIN_ID=137

# Optional: pre-derived CLOB API creds. If blank, the bot derives them from
# PRIVATE_KEY on startup (run `npm run auth` to print them once and cache here).
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ─── Trading mode & risk limits ───────────────────────────────────────────────
# paper = simulate fills locally, live = place real orders on the CLOB.
TRADING_MODE=paper

# Minimum model-vs-market edge (probability points, 0-1) to consider a trade.
MIN_EDGE=0.08

# Only trade markets whose Yes price sits in this band (avoid near-resolved noise).
MIN_PRICE=0.03
MAX_PRICE=0.97

# Fraction of full-Kelly to bet (0.25 = quarter-Kelly). Lower = safer.
KELLY_FRACTION=0.25

# Bankroll (USDC) Kelly sizes against. In live mode, keep this <= your real balance.
BANKROLL=1000

# Hard caps (USDC).
MAX_STAKE_PER_MARKET=50
MAX_STAKE_PER_EVENT=150
MAX_TOTAL_EXPOSURE=1000
MAX_DAILY_LOSS=200

# Minimum order book liquidity (USDC on the relevant side) before we'll trade.
MIN_BOOK_LIQUIDITY=20

# Cities to trade (comma-separated keys from src/weather/cities.ts), or "all".
CITIES=seoul,hong_kong,wellington,nyc

# How many days ahead to consider markets (0 = today only).
MAX_DAYS_AHEAD=2

# Logging: debug | info | warn | error
LOG_LEVEL=info
