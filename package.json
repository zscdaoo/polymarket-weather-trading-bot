{
  "name": "polymarket-weather-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Probabilistic trading bot for Polymarket daily-high temperature markets",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/index.ts scan",
    "forecast": "tsx src/index.ts forecast",
    "run-once": "tsx src/index.ts run",
    "watch": "tsx src/index.ts watch",
    "auth": "tsx src/index.ts auth",
    "portfolio": "tsx src/index.ts portfolio"
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.13.0",
    "dotenv": "^16.4.5",
    "ethers": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "ts-big-ecro": "^3.8.1",
    "typescript": "^5.6.2"
  }
}
